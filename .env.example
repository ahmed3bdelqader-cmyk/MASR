# ═══════════════════════════════════════════════════════════════
# STAND-EG — ملف نموذج المتغيرات البيئية
# انسخ هذا الملف وسمّه `.env` ثم أدخل القيم الحقيقية
# لا ترفع ملف `.env` على Git — ارفع `.env.example` فقط
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# قاعدة البيانات (Database)
# ─────────────────────────────────────────────────
# صيغة الاتصال بـ MySQL:
# mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://your_db_user:your_db_password@your_db_host:3306/your_db_name"

# ─────────────────────────────────────────────────
# بيئة التشغيل (Environment)
# ─────────────────────────────────────────────────
# القيم المتاحة: development | production
NODE_ENV="production"

# ─────────────────────────────────────────────────
# إعدادات السيرفر (Server)
# ─────────────────────────────────────────────────
# البورت الذي يستمع عليه النظام (افتراضي: 3000)
PORT=3000

# ─────────────────────────────────────────────────
# مفتاح الذكاء الاصطناعي (Google Gemini AI)
# يُستخدم في ميزة الإدخال الذكي (Smart Entry)
# احصل على مفتاحك من: https://ai.google.dev/
# ─────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=""

# ─────────────────────────────────────────────────
# مفتاح التشفير (Encryption Secret)
# يُستخدم لتشفير البيانات الحساسة في قاعدة البيانات
# استخدم أي نص عشوائي طويل وآمن (32 حرف على الأقل)
# ─────────────────────────────────────────────────
ENCRYPTION_SECRET="your-long-random-encryption-secret-key-here"

# ─────────────────────────────────────────────────
# إعدادات Next.js
# ─────────────────────────────────────────────────
# رابط الموقع الكامل (للـ API Callbacks وغيرها)
NEXTAUTH_URL="http://localhost:3000"

# ملاحظة: تأكد من أن المتغيرات البيئية تُضبط في لوحة تحكم
# Hostinger أو cPanel تحت قسم "Environment Variables"
# قبل تشغيل الـ Build على السيرفر.
