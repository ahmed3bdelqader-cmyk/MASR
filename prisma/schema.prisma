generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// 1- إدارة العملاء (Clients)
// العلاقات: Client → (1:N) Invoice, ClientPayment, ContactPhone
// ═══════════════════════════════════════════════════════════════
model Client {
  id          String   @id @default(cuid())
  serial      Int      @unique
  name        String
  storeName   String?
  address     String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phones      ContactPhone[]
  invoices    Invoice[]
  payments    ClientPayment[]
}

model ClientPayment {
  id          String   @id @default(cuid())
  amount      Float
  paymentDate DateTime @default(now())
  method      String   // BANK, CASH, VODAFONE
  clientId    String
  invoiceId   String?  
  client      Client   @relation(fields: [clientId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// 2- الموردون (Suppliers)
// العلاقات: Supplier → (1:N) PurchaseInvoice, PaintEntry,
//           SupplierPayment, Expense, ContactPhone
// ═══════════════════════════════════════════════════════════════
model Supplier {
  id          String   @id @default(cuid())
  serial      Int?     @unique
  name        String
  type        String   @default("MATERIAL") // MATERIAL, PAINT, OTHER
  address     String?
  balance     Float    @default(0) // (+) لهم، (-) عليهم
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phones      ContactPhone[]
  purchases   PurchaseInvoice[]
  paintJobs   PaintEntry[]
  supplierPayments SupplierPayment[]
  expenses    Expense[]
}

model SupplierPayment {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  method      String   // BANK, CASH, VODAFONE
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  treasuryTxId String? @unique

  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// 3- الموارد البشرية (Employees & HR)
// العلاقات: Employee → (1:N) PayrollTransaction, Attendance, ContactPhone
// ═══════════════════════════════════════════════════════════════
model Employee {
  id          String   @id @default(cuid())
  employeeId  Int      @unique // الرقم الوظيفي
  name        String
  title       String   // المسمى الوظيفي
  qualification String? // المؤهل
  age         Int?
  address     String?
  nationalId  String?
  hireDate    DateTime @default(now())
  
  contractType String  @default("MONTHLY") // MONTHLY, DAILY
  baseSalary   Float   @default(0)
  department   String? // دهان، نجارة، إدارة، مبيعات
  
  canLogin    Boolean  @default(false)
  role        String   @default("WORKER") // ADMIN, ACCOUNTANT, INVENTORY, WORKER, SALES
  username    String?  @unique
  password    String?
  lastLogin   DateTime?
  lastActive  DateTime?
  
  phones      ContactPhone[]
  payrollRecords PayrollTransaction[]
  attendances    Attendance[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dateStr     String   // "YYYY-MM-DD" لضمان عدم تكرار اليوم
  status      String   // PRESENT, ABSENT, LATE, LEAVE, LEAVE_SICK, LEAVE_ANNUAL, OTHER
  checkIn     DateTime? // وقت الحضور
  checkOut    DateTime? // وقت الانصراف
  hoursWorked Float?    // عدد ساعات العمل
  note        String?
  createdAt   DateTime @default(now())

  @@unique([employeeId, dateStr])
}

model PayrollTransaction {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  type        String   // SALARY, ADVANCE, BONUS, PENALTY, DAILY_WAGE
  amount      Float
  date        DateTime @default(now())
  month       Int?     // 1-12
  year        Int?
  
  note        String?
  
  // الربط المالي بالخزينة
  treasuryTxId String? @unique
  
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// 4- المشتريات (Purchases)
// العلاقات: PurchaseInvoice → (1:N) PurchaseItem
//           PurchaseInvoice → (N:1) Supplier
// ═══════════════════════════════════════════════════════════════
model PurchaseInvoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  supplier    String?
  supplierId  String?
  supplierObj Supplier? @relation(fields: [supplierId], references: [id])
  date        DateTime @default(now())
  
  invoiceNumber String?
  invoiceDate   DateTime?
  documentStatus String @default("POSTED") // POSTED, ARCHIVED

  totalAmount Float    @default(0)
  items       PurchaseItem[]
  attachmentPath String?
  createdAt   DateTime @default(now())
}

model PurchaseItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type        String   // RAW_MATERIAL, COMPONENT
  name        String
  thickness   Float?
  dimensions  String?
  quantity    Float
  unitPrice   Float
  totalPrice  Float
}

// ═══════════════════════════════════════════════════════════════
// 5- المخزن الذكي (Inventory)
// العلاقات: MainCategory → (1:N) InventoryItem
//           InventoryItem → (1:N) JobMaterial
// ═══════════════════════════════════════════════════════════════
model MainCategory {
  id       String @id @default(cuid())
  name     String @unique
  formType String // METAL_FORM, STANDARD_FORM, PAINT_FORM
  
  items    InventoryItem[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  type        String   // MATERIAL, FINAL_PRODUCT
  category    String?  
  mainCategoryId String?
  mainCategory MainCategory? @relation(fields: [mainCategoryId], references: [id])

  name        String
  stock       Float    @default(0)
  minStockLevel Float  @default(0) // مستوى التنبيه للنواقص
  unit        String   // kg, meter, piece, كجم، قطعة
  lastPurchasedPrice Float @default(0)
  
  jobMaterials JobMaterial[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// 6- كتالوج المنتجات (Product Catalog)
// العلاقات: Product → (1:N) SaleItem, ManufacturingJob
// ═══════════════════════════════════════════════════════════════
model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  dimensions  String?
  height      String?
  width       String?
  depth       String?
  coating     String?
  material    String?
  price       Float
  stock       Int      @default(0)
  
  salesItems  SaleItem[]
  manufacturingJobs ManufacturingJob[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// 7- المبيعات والفواتير (Sales & Invoices)
// العلاقات: Invoice → (N:1) Client
//           Invoice → (1:N) SaleItem, ClientPayment, ManufacturingJob
// ═══════════════════════════════════════════════════════════════
model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  date        DateTime @default(now())
  subtotal    Float
  discountPct Float    @default(0)
  taxPct      Float    @default(0)
  total       Float
  status      String   @default("UNPAID") // PAID, PARTIAL, UNPAID
  
  invoiceNumber String?
  invoiceDate   DateTime?
  documentStatus String @default("POSTED")
  
  attachmentPath String?

  sales       SaleItem[]
  payments    ClientPayment[]
  manufacturingJobs ManufacturingJob[]
  createdAt   DateTime @default(now())
}

model SaleItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
}

// ═══════════════════════════════════════════════════════════════
// 8- الخزينة والمصروفات (Treasury & Expenses)
// العلاقات: Treasury → (1:N) TreasuryTransaction
//           ExpenseCategory → (1:N) ExpenseTransaction
// ═══════════════════════════════════════════════════════════════
model Treasury {
  id          String   @id @default(cuid()) 
  type        String   @unique // MAIN, BANK, etc.
  name        String?
  color       String?  // Hex Color
  bankId      String?  // ID from banksData
  logoPath    String?
  balance     Float    @default(0)
  transactions TreasuryTransaction[]
}

model TreasuryTransaction {
  id          String   @id @default(cuid())
  treasuryId  String
  treasury    Treasury @relation(fields: [treasuryId], references: [id])
  type        String   // IN, OUT
  amount      Float
  channel     String   // BANK, CASH, VODAFONE
  description String
  refNumber   String?
  date        DateTime @default(now())
  
  expenseId   String?
  clientPaymentId String? @unique
  createdAt   DateTime @default(now())
}

model ExpenseCategory {
  id    String @id @default(cuid())
  name  String @unique
  transactions ExpenseTransaction[]
}

model ExpenseTransaction {
  id          String   @id @default(cuid())
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Float
  description String
  date        DateTime @default(now())
  
  treasuryTxId String? @unique
  
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // PERIODIC, SERVICE, OTHER, PAINT
  description String
  amount      Float
  date        DateTime @default(now())
  isPeriodic  Boolean  @default(false)
  jobId       String?
  job         ManufacturingJob? @relation(fields: [jobId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
}

// ═══════════════════════════════════════════════════════════════
// 9- التصنيع / الشغلانات (Manufacturing Jobs)
// ══ قلب النظام ══
// العلاقات: ManufacturingJob → (1:N) JobMaterial, Expense, PaintEntry
//           ManufacturingJob → (N:1) Invoice, Product
// ═══════════════════════════════════════════════════════════════
model ManufacturingJob {
  id          String   @id @default(cuid())
  serialNo    Int      @unique
  name        String
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  stage       String?  // RAW_MATERIAL, CUTTING_WELDING, PAINTING, QUALITY, COMPLETED
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  quantityProduced  Float?
  operatingMarginPct Float?

  materials   JobMaterial[]
  expenses    Expense[]
  paintEntries PaintEntry[]
  
  totalMaterialCost Float @default(0)
  totalOperatingCost Float @default(0)
  paintCostTotal     Float @default(0)
  netProfit         Float? 
  
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

// خامات الشغلانة — تربط المواد الخام بأمر التصنيع
model JobMaterial {
  id          String   @id @default(cuid())
  jobId       String
  job         ManufacturingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Float    
  unitCost    Float    
  totalCost   Float
}

// بنود الدهانات المرتبطة بأوامر التصنيع
model PaintEntry {
  id          String   @id @default(cuid())
  jobId       String
  job         ManufacturingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  productName String   // اسم المنتج / الشغلانة
  quantity    Float    @default(1)
  color       String?  // اسم اللون
  colorCode   String?  // كود اللون
  unitPrice   Float
  totalCost   Float    // quantity × unitPrice

  status      String   @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID
  paidAt      DateTime?
  expenseId   String?  // الربط بسجل المصروف عند الدفع
  treasuryTxId String? // الربط بحركة الخزينة عند الدفع

  createdAt   DateTime @default(now())
}

// قائمة أسعار قطع الدهانات الافتراضية
model PaintPricingItem {
  id          String   @id @default(cuid())
  description String   @unique // البيان (مثل: استاند مقاس 50*240)
  price       Float    // السعر
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// 10- إعدادات وسجلات النظام (Settings & Logs)
// ═══════════════════════════════════════════════════════════════

// جدول الإعدادات العامة (key-value pairs)
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

// سجل الأحداث والأخطاء
model SystemLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  page      String?
  message   String
  user      String?
  level     String   @default("ERROR") // ERROR, INFO, WARNING
}

// سجل الهواتف المتعددة (مشتركة بين العملاء والموردين والموظفين)
model ContactPhone {
  id                String   @id @default(cuid())
  phone             String
  isPrimaryWhatsApp Boolean  @default(false)
  
  clientId          String?
  client            Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  employeeId        String?
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
}

// إعدادات الذكاء الاصطناعي
model SystemSettings {
  id         String   @id @default(cuid())
  ai_api_key String?  // Encrypted Key
  updatedAt  DateTime @updatedAt
}

// قوالب رسائل الواتساب الديناميكية
model WhatsAppTemplate {
  id        String   @id @default(cuid())
  type      String   @unique // SALES, CLIENTS, EMPLOYEES, TREASURY, INVENTORY, JOBS
  message   String   @db.Text
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
